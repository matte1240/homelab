# =================================
# ESEMPIO CONFIGURAZIONE COMPLETA
# =================================
# Questo file mostra un esempio di configurazione completa
# dopo aver eseguito il setup interattivo

# =================================
# GENERAL CONFIGURATION
# =================================
TZ=Europe/Rome

# =================================
# CLOUDFLARE DDNS CONFIGURATION
# =================================
CLOUDFLARE_API_TOKEN=abcdef123456789abcdef123456789abcdef123456
DOMAINS=myhomelab.example.com

# =================================
# PI-HOLE CONFIGURATION
# =================================
PIHOLE_WEBPASSWORD=MySecurePassword123!
PIHOLE_SERVERIP=192.168.1.100

# =================================
# IMMICH CONFIGURATION
# =================================
IMMICH_UPLOAD_LOCATION=./services/media/uploads/library
IMMICH_DB_PASSWORD=AnotherSecurePassword456!
IMMICH_JWT_SECRET=randomGeneratedJWTSecretWith32Characters

# =================================
# NETWORK CONFIGURATION
# =================================
DOCKER_SUBNET=172.20.0.0/16

# =================================
# SMTP CONFIGURATION
# =================================
SMTP_HOSTNAME=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=myhomelab@gmail.com
SMTP_PASSWORD=myAppPassword789
SMTP_FROM_ADDRESS=myhomelab@gmail.com

# =================================
# ADVANCED CONFIGURATION (OPTIONAL)
# =================================
# Queste variabili sono configurate automaticamente
# ma possono essere personalizzate se necessario

# Traefik configuration
TRAEFIK_DASHBOARD_AUTH=admin:$2y$10$hashedpassword

# Database configurations
POSTGRES_USER=immich
POSTGRES_DB=immich

# Security settings
WATCHTOWER_CLEANUP=true
WATCHTOWER_INCLUDE_STOPPED=true

# Monitoring
UPTIME_KUMA_ADMIN_PASSWORD=SecureKumaPassword!
