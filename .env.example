# =================================
# HOMELAB ENVIRONMENT VARIABLES
# =================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# =================================
# GENERAL CONFIGURATION
# =================================
TZ=Europe/Rome

# =================================
# CLOUDFLARE DDNS CONFIGURATION
# =================================
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
DOMAINS=your-domain.com

# =================================
# PI-HOLE CONFIGURATION
# =================================
PIHOLE_WEBPASSWORD=your_secure_pihole_password
PIHOLE_SERVERIP=192.168.1.xxx

# =================================
# IMMICH CONFIGURATION
# =================================
IMMICH_UPLOAD_LOCATION=./immich/library
IMMICH_DB_USERNAME=immich
IMMICH_DB_PASSWORD=your_secure_postgres_password
IMMICH_DB_NAME=immich
IMMICH_JWT_SECRET=your_jwt_secret_here_min_32_chars

# =================================
# OPTIONAL: CUSTOM NETWORK
# =================================
# DOCKER_SUBNET=172.20.0.0/16

# =================================
# SECURITY CONFIGURATION
# =================================
VAULTWARDEN_ADMIN_TOKEN=your_secure_admin_token_here
CROWDSEC_BOUNCER_KEY=your_bouncer_key_here_32_chars_min

# =================================
# SMTP CONFIGURATION (Optional)
# =================================
# SMTP_HOSTNAME=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM_ADDRESS=your_email@gmail.com
