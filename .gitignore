# =================================
# SECURITY & ENVIRONMENT FILES
# =================================
.env
.env.local
.env.*.local

# =================================
# CONFIGURATION & DATA DIRECTORIES
# =================================
# Configurazioni private e dati runtime
config/
data/
*.log
*.db
*.db-*

# =================================
# SERVICE DATA DIRECTORIES
# =================================
# Dati specifici dei servizi (nuova struttura modulare)
services/*/data/
services/*/config/
services/*/uploads/
services/*/etc-*/
services/*/letsencrypt/

# =================================
# DOCKER VOLUMES & RUNTIME
# =================================
# Volumi Docker persistenti
**/docker-tls/
**/screenshots/
**/upload/

# Allow Traefik config files
!base-services/traefik/*.yml
!base-services/traefik/*.yaml

# =================================
# LOG FILES
# =================================
*.log
logs/

# =================================
# BACKUP FILES
# =================================
*.backup
backups/

# =================================
# TEMPORARY FILES
# =================================
.tmp/
tmp/

# =================================
# OS GENERATED FILES
# =================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# =================================
# EDITOR FILES
# =================================
.vscode/
.idea/
*.swp
*.swo
*~
